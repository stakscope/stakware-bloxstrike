local Settings = {
    AimbotEnabled = true,
    SilentAimEnabled = true,
    FOV = 200,
    TargetPart = "Head",
    AimbotSmoothing = 0.5,
    ToggleKey = Enum.KeyCode.LeftAlt,
    
    AimbotTeamCheck = true,
    ChamsTeamCheck = true,
    
    PlayerChamsEnabled = true,
    PlayerFillColor = Color3.fromRGB(0, 255, 0),
    PlayerOutlineColor = Color3.fromRGB(255, 255, 255),
    PlayerFillTransparency = 0.4,
    HealthBasedChams = true,
    
    WeaponChamsEnabled = true,
    WeaponFillColor = Color3.fromRGB(0, 255, 0),
    WeaponOutlineColor = Color3.fromRGB(255, 255, 255),
    WeaponFillTransparency = 0.25,
    
    MaxDistance = 300,
    IgnoreHostages = true,
}

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Chams = {}
local WeaponChams = {}
local MyTeam = nil
local ShootRemote = nil

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

-- Team Detection
task.spawn(function()
    task.wait(2)
    for i = 1, 10 do
        if LocalPlayer.Character then
            local charName = LocalPlayer.Character.Name
            for _, folder in ipairs(CharactersFolder:GetChildren()) do
                if folder:FindFirstChild(charName) then
                    MyTeam = folder.Name
                    print("✅ Team Detected:", MyTeam)
                    break
                end
            end
        end
        task.wait(1)
    end
end)

local function IsSameTeam(plr)
    if not Settings.AimbotTeamCheck or not MyTeam then return false end
    if not plr.Character then return false end
    local charName = plr.Character.Name
    for _, folder in ipairs(CharactersFolder:GetChildren()) do
        if folder:FindFirstChild(charName) and folder.Name == MyTeam then
            return true
        end
    end
    return false
end

local function CreateHighlight(fillColor, outlineColor, fillTrans)
    local h = Instance.new("Highlight")
    h.FillColor = fillColor
    h.OutlineColor = outlineColor
    h.FillTransparency = fillTrans
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = game:GetService("CoreGui")
    return h
end

local function GetHealthColor(health, maxHealth)
    local p = math.clamp(health / maxHealth, 0, 1)
    return Color3.fromRGB((1-p)*255, p*255, 50)
end

local function UpdateChams(plr)
    if plr == LocalPlayer then return end
    if Settings.IgnoreHostages and GetPlayerTeam and GetPlayerTeam(plr) == "Hostages" then return end
    if Settings.ChamsTeamCheck and IsSameTeam(plr) then return end

    local char = plr.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    if Settings.PlayerChamsEnabled then
        if not Chams[plr] then Chams[plr] = CreateHighlight(Settings.PlayerFillColor, Settings.PlayerOutlineColor, Settings.PlayerFillTransparency) end
        if Settings.HealthBasedChams then
            Chams[plr].FillColor = GetHealthColor(hum.Health, hum.MaxHealth)
        end
        Chams[plr].Adornee = char
    end

    if Settings.WeaponChamsEnabled then
        local debris = Workspace:FindFirstChild("Debris")
        local weapon = debris and debris:FindFirstChild(plr.Name .. "_Weapon")
        if weapon then
            if not WeaponChams[plr] then
                WeaponChams[plr] = CreateHighlight(Settings.WeaponFillColor, Settings.WeaponOutlineColor, Settings.WeaponFillTransparency)
            end
            WeaponChams[plr].Adornee = weapon
        end
    end
end

-- Find Remote
task.spawn(function()
    task.wait(3)
    for _, v in ipairs(game:GetDescendants()) do
        if v.Name == "ShootWeapon" and v:IsA("RemoteEvent") then
            ShootRemote = v
            print("✅ ShootWeapon Remote Found!")
            break
        end
    end
end)

-- Silent Aim Hook (Safer version)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if silentAimEnabled and ShootRemote and self == ShootRemote and method == "FireServer" then
        local closest = nil
        local best = Settings.FOV + 1
        local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer or IsSameTeam(plr) then continue end
            local char = plr.Character
            if not char then continue end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end

            local part = char:FindFirstChild(Settings.TargetPart) or char:FindFirstChild("HumanoidRootPart")
            if part then
                local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                    if d < best then
                        closest = part
                        best = d
                    end
                end
            end
        end

        if closest and args[1] and typeof(args[1]) == "Vector3" then
            args[1] = (closest.Position - Camera.CFrame.Position).Unit * 1000
        end
    end

    return oldNamecall(self, unpack(args))
end)

-- Main Loops
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            UpdateChams(plr)
        end
    end
end)

-- FOV Circle + Visual Aimbot
local Circle = Drawing.new("Circle")
Circle.Thickness = 2
Circle.Color = Color3.fromRGB(255, 0, 0)
Circle.Transparency = 0.6
Circle.Filled = false
Circle.Visible = true

UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Settings.ToggleKey then
        Settings.AimbotEnabled = not Settings.AimbotEnabled
        Settings.SilentAimEnabled = Settings.AimbotEnabled
        print("Aimbot:", Settings.AimbotEnabled)
    end
end)

print("✅ Bloxstrike Simple Script Loaded | FOV =", Settings.FOV)
