    local network = Workspace:FindFirstChild("Network", true) or game
    for _, v in ipairs(network:GetDescendants()) do
        if v.Name == "ShootWeapon" then
            ShootRemote = v
            print("✅ Found ShootWeapon Remote!")
            break
        end
    end
    if not ShootRemote then
        print("⚠️ Could not find ShootWeapon remote")
    end
end)

-- Hook shooting
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if silentAimEnabled and ShootRemote and self == ShootRemote and method == "FireServer" then
        local targetPart = GetClosestTarget()
        if targetPart then
            -- Modify direction to target (Silent Aim)
            if args[1] and typeof(args[1]) == "Vector3" then
                local direction = (targetPart.Position - Camera.CFrame.Position).Unit
                args[1] = direction * 1000 -- or whatever scale the game uses
            end
        end
    end

    return oldNamecall(self, unpack(args))
end)

setreadonly(mt, true)

