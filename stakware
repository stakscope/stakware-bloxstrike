local Settings = {
    -- ================== AIMBOT ==================
    AimbotEnabled = true,
    FOV = 120,
    TargetPart = "Head",
    WallCheck = false,
    AimbotSmoothing = 0.48,
    ToggleKey = Enum.KeyCode.LeftAlt,
    
    -- ================== TEAM CHECK ==================
    AimbotTeamCheck = true,
    ChamsTeamCheck = true,
    
    -- ================== CHAMS ==================
    PlayerChamsEnabled = true,
    PlayerFillColor = Color3.fromRGB(0, 255, 0),
    PlayerOutlineColor = Color3.fromRGB(255, 255, 255),
    PlayerFillTransparency = 0.6,          -- More transparent so weapon shows better
    
    HealthBasedChams = true,
    
    WeaponChamsEnabled = true,
    WeaponFillColor = Color3.fromRGB(0, 255, 255),     -- Cyan
    WeaponOutlineColor = Color3.fromRGB(255, 0, 255),
    WeaponFillTransparency = 0.05,                     -- Almost solid
    
    -- ================== OTHER ==================
    MaxDistance = 300,
    IgnoreHostages = true,
}

-- =====================================================
-- MAIN SCRIPT
-- =====================================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local aimbotEnabled = Settings.AimbotEnabled
local Chams = {}
local WeaponChams = {}
local MyTeam = nil

print("Stakware Loaded | HealthBased:", Settings.HealthBasedChams)

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

-- ================== FUNCTIONS ==================

local function DetectMyTeam()
    if not LocalPlayer.Character or not CharactersFolder then return nil end
    local charName = LocalPlayer.Character.Name
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            if MyTeam ~= teamFolder.Name then
                MyTeam = teamFolder.Name
                print("✅ Team Updated: " .. MyTeam)
            end
            return MyTeam
        end
    end
    return nil
end

local function GetPlayerTeam(plr)
    if not CharactersFolder or not plr.Character then return nil end
    local charName = plr.Character.Name
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            return teamFolder.Name
        end
    end
    return nil
end

local function RemovePlayer(plr)
    if Chams[plr] then Chams[plr]:Destroy() Chams[plr] = nil end
    if WeaponChams[plr] then WeaponChams[plr]:Destroy() WeaponChams[plr] = nil end
end

local function IsSameTeam(plr, isForChams)
    if not MyTeam then return false end
    local useTeamCheck = isForChams and Settings.ChamsTeamCheck or Settings.AimbotTeamCheck
    if not useTeamCheck then return false end
    local theirTeam = GetPlayerTeam(plr)
    if not theirTeam then return false end
    return theirTeam == MyTeam
end

local function CreateHighlight(fillColor, outlineColor, fillTrans)
    local h = Instance.new("Highlight")
    h.FillColor = fillColor
    h.OutlineColor = outlineColor
    h.FillTransparency = fillTrans
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = game:GetService("CoreGui")
    return h
end

local function GetHealthColor(health, maxHealth)
    local percent = math.clamp(health / maxHealth, 0, 1)
    local r = (1 - percent) * 255
    local g = percent * 255
    return Color3.fromRGB(r, g, 50)
end

local function GetWeaponModel(plr)
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return nil end
    return debris:FindFirstChild(plr.Name .. "_Weapon")
end

local function UpdateChams(plr)
    if plr == LocalPlayer then return end
    
    if Settings.IgnoreHostages then
        local theirTeam = GetPlayerTeam(plr)
        if theirTeam == "Hostages" then
            RemovePlayer(plr)
            return
        end
    end
    
    if Settings.ChamsTeamCheck and IsSameTeam(plr, true) then
        RemovePlayer(plr)
        return
    end
    
    local char = plr.Character
    if not char then 
        RemovePlayer(plr)
        return 
    end
   
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then 
        RemovePlayer(plr)
        return 
    end
    
    -- PLAYER CHAMS (more transparent)
    if Settings.PlayerChamsEnabled then
        if not Chams[plr] then
            Chams[plr] = CreateHighlight(Settings.PlayerFillColor, Settings.PlayerOutlineColor, Settings.PlayerFillTransparency)
        end
        
        if Settings.HealthBasedChams and hum.MaxHealth > 0 then
            Chams[plr].FillColor = GetHealthColor(hum.Health, hum.MaxHealth)
        else
            Chams[plr].FillColor = Settings.PlayerFillColor
        end
        Chams[plr].Adornee = char
    end
    
    -- WEAPON CHAMS (high priority)
    if Settings.WeaponChamsEnabled then
        local weapon = GetWeaponModel(plr)
        if weapon then
            if not WeaponChams[plr] then
                WeaponChams[plr] = CreateHighlight(Settings.WeaponFillColor, Settings.WeaponOutlineColor, Settings.WeaponFillTransparency)
            end
            WeaponChams[plr].Adornee = weapon
        elseif WeaponChams[plr] then
            WeaponChams[plr].Adornee = nil
        end
    end
end

-- ================== CONNECTIONS ==================

task.spawn(function()
    for i = 1, 8 do
        task.wait(1)
        if DetectMyTeam() then break end
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    DetectMyTeam()
end)

task.spawn(function()
    while true do
        task.wait(5)
        DetectMyTeam()
    end
end)

Players.PlayerRemoving:Connect(RemovePlayer)

RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            UpdateChams(plr)
        end
    end
end)

-- ================== AIMBOT ==================
local Circle = Drawing.new("Circle")
Circle.Thickness = 2
Circle.Color = Color3.fromRGB(255, 0, 0)
Circle.Transparency = 0.6
Circle.Filled = false
Circle.Visible = true

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Settings.ToggleKey then
        aimbotEnabled = not aimbotEnabled
        print("Aimbot toggled:", aimbotEnabled)
    end
end)

RunService.RenderStepped:Connect(function()
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    Circle.Position = ScreenCenter
    Circle.Radius = Settings.FOV
    
    if not aimbotEnabled or not MyTeam then return end
    
    local bestTarget = nil
    local bestDist = Settings.FOV + 1
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if IsSameTeam(plr, false) then continue end
        
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
       
        local part = char:FindFirstChild(Settings.TargetPart) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - ScreenCenter).Magnitude
            if dist < bestDist then
                bestTarget = Vector2.new(screenPos.X, screenPos.Y)
                bestDist = dist
            end
        end
    end
    
    if bestTarget then
        local deltaX = bestTarget.X - ScreenCenter.X
        local deltaY = bestTarget.Y - ScreenCenter.Y
        local smoothX = deltaX * Settings.AimbotSmoothing
        local smoothY = deltaY * Settings.AimbotSmoothing
        mousemoverel(smoothX, smoothY)
    end
end)

print("✅ Weapon Priority Fixed - Player more transparent, Weapon almost solid")
