local Settings = {
    AimbotEnabled = true,
    SilentAimEnabled = true,
    FOV = 90,                    -- Start with 90, you can change it
    TargetPart = "Head",
    AimbotSmoothing = 0.5,
    ToggleKey = Enum.KeyCode.LeftAlt,
    
    AimbotTeamCheck = true,
    ChamsTeamCheck = true,
    
    PlayerChamsEnabled = true,
    PlayerFillColor = Color3.fromRGB(0, 255, 0),
    PlayerOutlineColor = Color3.fromRGB(255, 255, 255),
    PlayerFillTransparency = 0.4,
    HealthBasedChams = true,
    
    WeaponChamsEnabled = true,
    WeaponFillColor = Color3.fromRGB(0, 255, 0),
    WeaponOutlineColor = Color3.fromRGB(255, 255, 255),
    WeaponFillTransparency = 0.25,
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Chams = {}
local WeaponChams = {}
local MyTeam = nil
local ShootRemote = nil

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

-- Team Detection
task.spawn(function()
    task.wait(1.5)
    while true do
        if LocalPlayer.Character then
            local name = LocalPlayer.Character.Name
            for _, folder in ipairs(CharactersFolder:GetChildren()) do
                if folder:FindFirstChild(name) then
                    if MyTeam ~= folder.Name then
                        MyTeam = folder.Name
                        print("✅ Team:", MyTeam)
                    end
                    break
                end
            end
        end
        task.wait(5)
    end
end)

local function IsSameTeam(plr)
    if not Settings.AimbotTeamCheck or not MyTeam then return false end
    if not plr.Character then return false end
    local name = plr.Character.Name
    for _, f in ipairs(CharactersFolder:GetChildren()) do
        if f:FindFirstChild(name) and f.Name == MyTeam then return true end
    end
    return false
end

local function CreateHighlight(c1, c2, t)
    local h = Instance.new("Highlight")
    h.FillColor = c1
    h.OutlineColor = c2
    h.FillTransparency = t
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = game:GetService("CoreGui")
    return h
end

local function GetHealthColor(h, mh)
    local p = math.clamp(h / mh, 0, 1)
    return Color3.fromRGB((1-p)*255, p*255, 50)
end

local function UpdateChams(plr)
    if plr == LocalPlayer then return end
    if Settings.ChamsTeamCheck and IsSameTeam(plr) then return end

    local char = plr.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    if Settings.PlayerChamsEnabled then
        if not Chams[plr] then
            Chams[plr] = CreateHighlight(Settings.PlayerFillColor, Settings.PlayerOutlineColor, Settings.PlayerFillTransparency)
        end
        if Settings.HealthBasedChams then
            Chams[plr].FillColor = GetHealthColor(hum.Health, hum.MaxHealth)
        end
        Chams[plr].Adornee = char
    end

    if Settings.WeaponChamsEnabled then
        local debris = Workspace:FindFirstChild("Debris")
        local w = debris and debris:FindFirstChild(plr.Name.."_Weapon")
        if w then
            if not WeaponChams[plr] then
                WeaponChams[plr] = CreateHighlight(Settings.WeaponFillColor, Settings.WeaponOutlineColor, Settings.WeaponFillTransparency)
            end
            WeaponChams[plr].Adornee = w
        end
    end
end

-- Find Remote
task.spawn(function()
    task.wait(2)
    for _, v in ipairs(game:GetDescendants()) do
        if v.Name == "ShootWeapon" and v:IsA("RemoteEvent") then
            ShootRemote = v
            print("✅ ShootWeapon Found!")
            break
        end
    end
end)

-- ================== SILENT AIM (Safer) ==================
local function GetClosestTarget()
    local best, dist = nil, Settings.FOV + 1
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, plr in Players:GetPlayers() do
        if plr == LocalPlayer or IsSameTeam(plr) then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local part = char:FindFirstChild(Settings.TargetPart) or char:FindFirstChild("HumanoidRootPart")
        if part then
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if d < dist then
                    best = part
                    dist = d
                end
            end
        end
    end
    return best
end

-- Try hook (safer)
if hookmetamethod then
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local args = {...}
        if silentAimEnabled and ShootRemote and self == ShootRemote and getnamecallmethod() == "FireServer" then
            local target = GetClosestTarget()
            if target and args[1] and typeof(args[1]) == "Vector3" then
                args[1] = (target.Position - Camera.CFrame.Position).Unit * 1000
            end
        end
        return oldNamecall(self, unpack(args))
    end)
    print("✅ Hookmetamethod applied")
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then UpdateChams(plr) end
    end
end)

