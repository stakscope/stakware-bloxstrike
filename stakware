task.spawn(function()
    local Camera = workspace.CurrentCamera
    local ScreenSize = Camera.ViewportSize
    
    local Overlay = Drawing.new("Square")
    Overlay.Size = ScreenSize
    Overlay.Position = Vector2.new(0, 0)
    Overlay.Color = Color3.fromRGB(0, 0, 0)
    Overlay.Filled = true
    Overlay.Transparency = 1
    Overlay.Visible = true

    local Text = Drawing.new("Text")
    Text.Text = "stakware"
    Text.Size = 45
    Text.Center = true
    Text.Outline = true
    Text.Color = Color3.fromRGB(255, 255, 255)
    Text.Position = Vector2.new(ScreenSize.X / 2, ScreenSize.Y / 2)
    Text.Transparency = 1
    Text.Visible = true

    task.wait(1.5) 

    for i = 1, 30 do
        local pulse = 1 - (math.sin(i / 5) * 0.2)
        Text.Transparency = pulse
        task.wait(0.05)
