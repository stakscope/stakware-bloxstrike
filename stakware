local Settings = {
    -- ================== AIMBOT ==================
    AimbotEnabled = true,
    FOV = 120,
    TargetPart = "Head",
    AimbotSmoothing = 0.48,
    ToggleKey = Enum.KeyCode.LeftAlt,
    
    -- ================== TEAM CHECK ==================
    AimbotTeamCheck = true,
    ChamsTeamCheck = true,
    
    -- ================== CHAMS ==================
    PlayerChamsEnabled = true,
    PlayerFillColor = Color3.fromRGB(0, 255, 0),
    PlayerOutlineColor = Color3.fromRGB(255, 255, 255),
    PlayerFillTransparency = 0.4,
    HealthBasedChams = true,
    
    WeaponChamsEnabled = true,
    WeaponFillColor = Color3.fromRGB(0, 255, 255),
    WeaponOutlineColor = Color3.fromRGB(255, 0, 255),
    WeaponFillTransparency = 0.0,
    
    -- ================== OTHER ==================
    MaxDistance = 300,
    IgnoreHostages = true,
}

-- =====================================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Chams = {}
local WeaponChams = {}
local MyTeam = nil

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

local function DetectMyTeam()
    if not LocalPlayer.Character or not CharactersFolder then return nil end
    local charName = LocalPlayer.Character.Name
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            if MyTeam ~= teamFolder.Name then
                MyTeam = teamFolder.Name
                print("✅ Team Updated: " .. MyTeam)
            end
            return MyTeam
        end
    end
    return nil
end

local function GetPlayerTeam(plr)
    if not CharactersFolder or not plr.Character then return nil end
    local charName = plr.Character.Name
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            return teamFolder.Name
        end
    end
    return nil
end

local function RemovePlayer(plr)
    if Chams[plr] then Chams[plr]:Destroy() Chams[plr] = nil end
    if WeaponChams[plr] then 
        for _, h in pairs(WeaponChams[plr]) do h:Destroy() end
        WeaponChams[plr] = nil 
    end
end

local function IsSameTeam(plr, isForChams)
    if not MyTeam then return false end
    local useTeamCheck = isForChams and Settings.ChamsTeamCheck or Settings.AimbotTeamCheck
    if not useTeamCheck then return false end
    local theirTeam = GetPlayerTeam(plr)
    if not theirTeam then return false end
    return theirTeam == MyTeam
end

local function CreateHighlight(fillColor, outlineColor, fillTrans, depth)
    local h = Instance.new("Highlight")
    h.FillColor = fillColor
    h.OutlineColor = outlineColor
    h.FillTransparency = fillTrans
    h.OutlineTransparency = 0
    h.DepthMode = depth or Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = game:GetService("CoreGui")
    return h
end

local function GetHealthColor(health, maxHealth)
    local percent = math.clamp(health / maxHealth, 0, 1)
    local r = (1 - percent) * 255
    local g = percent * 255
    return Color3.fromRGB(r, g, 50)
end

local function GetWeaponModel(plr)
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return nil end
    return debris:FindFirstChild(plr.Name .. "_Weapon")
end

local function UpdateChams(plr)
    if plr == LocalPlayer then return end
    
    if Settings.IgnoreHostages and GetPlayerTeam(plr) == "Hostages" then
        RemovePlayer(plr) return
    end
    if Settings.ChamsTeamCheck and IsSameTeam(plr, true) then
        RemovePlayer(plr) return
    end

    local char = plr.Character
    if not char then RemovePlayer(plr) return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then RemovePlayer(plr) return end

    -- Player Chams
    if Settings.PlayerChamsEnabled then
        if not Chams[plr] then
            Chams[plr] = CreateHighlight(Settings.PlayerFillColor, Settings.PlayerOutlineColor, Settings.PlayerFillTransparency, Enum.HighlightDepthMode.Occluded)
        end
        if Settings.HealthBasedChams then
            Chams[plr].FillColor = GetHealthColor(hum.Health, hum.MaxHealth)
        end
        Chams[plr].Adornee = char
    end

    -- Weapon Chams (Individual Parts + AlwaysOnTop)
    if Settings.WeaponChamsEnabled then
        local weapon = GetWeaponModel(plr)
        if weapon then
            if not WeaponChams[plr] then WeaponChams[plr] = {} end
            
            for _, part in ipairs(weapon:GetDescendants()) do
                if part:IsA("BasePart") and part.Transparency < 0.9 then
                    local alreadyHighlighted = false
                    for _, h in ipairs(WeaponChams[plr]) do
                        if h.Adornee == part then alreadyHighlighted = true break end
                    end
                    if not alreadyHighlighted then
                        local wh = CreateHighlight(Settings.WeaponFillColor, Settings.WeaponOutlineColor, Settings.WeaponFillTransparency)
                        wh.Adornee = part
                        table.insert(WeaponChams[plr], wh)
                    end
                end
            end
        else
            if WeaponChams[plr] then
                for _, h in pairs(WeaponChams[plr]) do h:Destroy() end
                WeaponChams[plr] = nil
            end
        end
    end
end

-- Connections
task.spawn(function()
    for i = 1, 10 do task.wait(1) if DetectMyTeam() then break end end
end)

LocalPlayer.CharacterAdded:Connect(function() task.wait(1) DetectMyTeam() end)

task.spawn(function()
    while true do task.wait(5) DetectMyTeam() end
end)

Players.PlayerRemoving:Connect(RemovePlayer)

RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then UpdateChams(plr) end
    end
end)

