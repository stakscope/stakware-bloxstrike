local Settings = {
    SilentAimEnabled = true,
    FOV = 90,                    -- Change this (lower = more accurate)
    TargetPart = "Head",
    TeamCheck = true,
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local MyTeam = nil
local ShootRemote = nil

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

-- Auto Team Detect
task.spawn(function()
    task.wait(2)
    while true do
        if LocalPlayer.Character then
            local name = LocalPlayer.Character.Name
            for _, folder in ipairs(CharactersFolder:GetChildren()) do
                if folder:FindFirstChild(name) then
                    MyTeam = folder.Name
                    print("Team:", MyTeam)
                    break
                end
            end
        end
        task.wait(5)
    end
end)

local function IsSameTeam(plr)
    if not Settings.TeamCheck or not MyTeam then return false end
    if not plr.Character then return false end
    local name = plr.Character.Name
    for _, f in ipairs(CharactersFolder:GetChildren()) do
        if f:FindFirstChild(name) and f.Name == MyTeam then
            return true
        end
    end
    return false
end

local function GetClosestTarget()
    local closest = nil
    local bestDist = Settings.FOV + 1
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or IsSameTeam(plr) then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local part = char:FindFirstChild(Settings.TargetPart) or char:FindFirstChild("HumanoidRootPart")
        if part then
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < bestDist then
                    closest = part
                    bestDist = dist
                end
            end
        end
    end
    return closest
end

-- Find Remote
task.spawn(function()
    task.wait(2)
    for _, v in ipairs(game:GetDescendants()) do
        if v.Name == "ShootWeapon" and v:IsA("RemoteEvent") then
            ShootRemote = v
            print("✅ ShootWeapon Remote Found!")
            break
        end
    end
end)

-- Silent Aim Hook
if hookmetamethod then
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local args = {...}
        local method = getnamecallmethod()

        if Settings.SilentAimEnabled and ShootRemote and self == ShootRemote and method == "FireServer" then
            local target = GetClosestTarget()
            if target and args[1] and typeof(args[1]) == "Vector3" then
                args[1] = (target.Position - Camera.CFrame.Position).Unit * 1000
            end
        end

        return oldNamecall(self, unpack(args))
    end)
    print("✅ Silent Aim Hook Applied")
else
    print("❌ Your executor doesn't support hookmetamethod")
end

print("✅ Silent Aim Script Loaded | FOV:", Settings.FOV, "| TeamCheck:", Settings.TeamCheck)
