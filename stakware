    if gp then return end
    if i.KeyCode == Settings.ToggleKey then
        Settings.AimbotEnabled = not Settings.AimbotEnabled
        Settings.SilentAimEnabled = Settings.AimbotEnabled
        print("Aimbot + Silent Aim:", Settings.AimbotEnabled)
    end
end)

print("✅ Bloxstrike Script Loaded | FOV:", Settings.FOV, "| Silent Aim:", Settings.SilentAimEnabled)
