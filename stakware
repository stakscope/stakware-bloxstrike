local Settings = {
    AimbotEnabled = true,
    FOV = 90,
    TargetPart = "Head",
    AimbotSmoothing = 0.45,
    ToggleKey = Enum.KeyCode.LeftAlt,
    
    TeamCheck = true,
    
    PlayerChamsEnabled = true,
    PlayerFillColor = Color3.fromRGB(0, 255, 0),
    PlayerOutlineColor = Color3.fromRGB(255, 255, 255),
    PlayerFillTransparency = 0.35,
    HealthBasedChams = true,
    
    WeaponChamsEnabled = true,
    WeaponFillColor = Color3.fromRGB(0, 255, 0),
    WeaponOutlineColor = Color3.fromRGB(255, 255, 255),
    WeaponFillTransparency = 0.2,
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Chams = {}
local WeaponChams = {}
local MyTeam = nil

local CharactersFolder = Workspace:WaitForChild("Characters", 15)

-- ================== IMPROVED TEAM DETECTION ==================
local function UpdateMyTeam()
    if not LocalPlayer.Character then return end
    
    local charName = LocalPlayer.Character.Name
    
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            if MyTeam ~= teamFolder.Name then
                MyTeam = teamFolder.Name
                print("✅ Team Updated:", MyTeam)
            end
            return MyTeam
        end
    end
end

-- Strong team detection
task.spawn(function()
    task.wait(1)
    while true do
        UpdateMyTeam()
        task.wait(3)  -- Check every 3 seconds
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.8)
    UpdateMyTeam()
end)

local function IsSameTeam(plr)
    if not Settings.TeamCheck or not MyTeam then return false end
    if not plr.Character then return false end
    
    local charName = plr.Character.Name
    
    for _, teamFolder in ipairs(CharactersFolder:GetChildren()) do
        if teamFolder:IsA("Folder") and teamFolder:FindFirstChild(charName) then
            return teamFolder.Name == MyTeam
        end
    end
    return false
end

local function CreateHighlight(fill, outline, trans)
    local h = Instance.new("Highlight")
    h.FillColor = fill
    h.OutlineColor = outline
    h.FillTransparency = trans
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = game:GetService("CoreGui")
    return h
end

local function GetHealthColor(health, maxhealth)
    local p = math.clamp(health / maxhealth, 0, 1)
    return Color3.fromRGB((1-p)*255, p*255, 50)
end

local function UpdateChams(plr)
    if plr == LocalPlayer then return end
    if IsSameTeam(plr) then 
        -- Remove chams from teammates
        if Chams[plr] then Chams[plr]:Destroy() Chams[plr] = nil end
        if WeaponChams[plr] then WeaponChams[plr]:Destroy() WeaponChams[plr] = nil end
        return 
    end

    local char = plr.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    if Settings.PlayerChamsEnabled then
        if not Chams[plr] then
            Chams[plr] = CreateHighlight(Settings.PlayerFillColor, Settings.PlayerOutlineColor, Settings.PlayerFillTransparency)
        end
        if Settings.HealthBasedChams then
            Chams[plr].FillColor = GetHealthColor(hum.Health, hum.MaxHealth)
        end
        Chams[plr].Adornee = char
    end

    if Settings.WeaponChamsEnabled then
        local debris = Workspace:FindFirstChild("Debris")
        local weapon = debris and debris:FindFirstChild(plr.Name .. "_Weapon")
        if weapon then
            if not WeaponChams[plr] then
                WeaponChams[plr] = CreateHighlight(Settings.WeaponFillColor, Settings.WeaponOutlineColor, Settings.WeaponFillTransparency)
            end
            WeaponChams[plr].Adornee = weapon
        end
    end
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            UpdateChams(plr)
        end
    end
end)

-- Visual Aimbot + FOV
local Circle = Drawing.new("Circle")
Circle.Thickness = 2
Circle.Color = Color3.fromRGB(255, 0, 0)
Circle.Transparency = 0.6
Circle.Filled = false
Circle.Visible = true

UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Settings.ToggleKey then
        Settings.AimbotEnabled = not Settings.AimbotEnabled
        print("Aimbot:", Settings.AimbotEnabled)
    end
end)

RunService.RenderStepped:Connect(function()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    Circle.Position = center
    Circle.Radius = Settings.FOV

    if not Settings.AimbotEnabled or not MyTeam then return end

    local best = nil
    local bestDist = Settings.FOV + 1

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or IsSameTeam(plr) then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local part = char:FindFirstChild(Settings.TargetPart) or char:FindFirstChild("HumanoidRootPart")
        if part then
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = Vector2.new(pos.X, pos.Y)
                end
            end
        end
    end

    if best then
        mousemoverel((best.X - center.X) * Settings.AimbotSmoothing, (best.Y - center.Y) * Settings.AimbotSmoothing)
    end
end)

print("✅ Improved TeamCheck + ESP Loaded | FOV:", Settings.FOV)
